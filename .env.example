# .env.example — copy this file to .env and fill in your values
# The .env file is git-ignored and never baked into the Docker image.
#
#   cp .env.example .env
#   nano .env   # add your keys

# Your student last name (lowercase)
STUDENT_ID=yourlastname

# DeepSeek LLM API key (shared — provided by instructor)
DEEPSEEK_API_KEY=sk-...

# Langfuse observability keys (shared — provided by instructor)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ROS2 domain ID (0 = default; change if multiple robots share the network)
ROS_DOMAIN_ID=0
